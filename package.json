{
  "name": "@fiduswriter/bibliography-manager",
  "version": "0.1.20",
  "description": "Fidus Writer bibliography manager",
  "repository": {
    "type": "git",
    "url": "ssh://git@codeberg.org/fiduswriter/fiduswriter-bibliography-manager-js.git"
  },
  "license": "AGPL-3.0",
  "author": "Johannes Wilm",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./overview": {
      "types": "./dist/overview/index.d.ts",
      "default": "./dist/overview/index.js"
    },
    "./form": {
      "types": "./dist/form/index.d.ts",
      "default": "./dist/form/index.js"
    },
    "./database": {
      "types": "./dist/database/index.d.ts",
      "default": "./dist/database/index.js"
    },
    "./import": {
      "types": "./dist/import/index.d.ts",
      "default": "./dist/import/index.js"
    },
    "./export": {
      "types": "./dist/export/index.d.ts",
      "default": "./dist/export/index.js"
    },
    "./bibliojson": {
      "types": "./dist/bibliojson.d.ts",
      "default": "./dist/bibliojson.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE",
    "logo.svg"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js",
    "install-hooks": "husky"
  },
  "dependencies": {
    "bibliojson": "^4.0.4",
    "fix-utf8": "2.0.1",
    "fwtoolkit": "^0.2.0",
    "prosemirror-model": "^1.25.0",
    "simple-datatables": "^10.2.0",
    "tokenfield": "^1.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "eslint": "^10.6.0",
    "globals": "^15.15.0",
    "happy-dom": "^20.10.6",
    "jest": "^30.4.2",
    "prettier": "^3.5.3",
    "ts-jest": "^29.4.11",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  },
  "lint-staged": {
    "*.{ts,js,mjs,css,md,json,html}": [
      "prettier --write"
    ],
    "*.{ts,js,mjs}": [
      "eslint --fix",
      "sh -c 'npm run typecheck'"
    ]
  }
}
